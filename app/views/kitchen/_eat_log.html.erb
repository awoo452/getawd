<div class="meal-planner-table">

  <%# Header row — same dates as the cook planner %>
  <div class="meal-planner-row">
    <div class="meal-planner-label"></div>
    <% @week_dates.each do |date| %>
      <div class="meal-planner-header-cell day-col-<%= date.wday %> <%= 'meal-planner-today' if date == Time.zone.today %>">
        <span class="meal-planner-day-name"><%= date.strftime("%a") %></span>
        <span class="meal-planner-day-num"><%= date.strftime("%-d") %></span>
      </div>
    <% end %>
  </div>

  <%# Eat log slot rows %>
  <% EatLog::SLOTS.each do |slot| %>
    <div class="meal-planner-row">
      <div class="meal-planner-label meal-planner-slot-label">
        <%= slot.capitalize %>
      </div>
      <% @week_dates.each do |date| %>
        <%= render "kitchen/eat_log_cell",
              date:            date,
              slot:            slot,
              eat_logs:        @eat_logs_by_date_slot[[date, slot]] || [],
              prepared_dishes: @prepared_dishes %>
      <% end %>
    </div>
  <% end %>

</div>
