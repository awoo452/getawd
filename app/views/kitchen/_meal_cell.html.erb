<div id="meal_cell_<%= date.iso8601 %>_<%= slot %>" class="meal-planner-day-cell day-col-<%= date.wday %>">
  <% if meal_plan %>
    <% meal_plan.recipes.each do |recipe| %>
      <% mpr = meal_plan.meal_plan_recipes.find { |r| r.recipe_id == recipe.id } %>
      <div class="meal-plan-recipe-row">
        <span class="meal-planner-recipe-name"><%= recipe.name %><%= " ×#{mpr.quantity}" if mpr.quantity > 1 %></span>
        <%= button_to "×", meal_plan_recipe_path(mpr),
              method: :delete,
              class: "meal-planner-remove",
              form: { data: { turbo_confirm: "Remove #{recipe.name}?" } } %>
      </div>
    <% end %>

    <% meal_plan.meal_plan_items.each do |item| %>
      <div class="meal-plan-item-row">
        <span class="meal-plan-item-name"><%= item.food_item.name %> (<%= item.quantity %>)</span>
        <%= button_to "×", meal_plan_item_path(item),
              method: :delete,
              class: "meal-planner-remove" %>
      </div>
    <% end %>

    <div class="meal-planner-add-row">
      <%= form_with url: meal_plan_recipes_path, class: "meal-planner-add-form" do |f| %>
        <%= f.hidden_field :planned_on, value: date %>
        <%= f.hidden_field :meal_slot,  value: slot %>
        <%= f.select :recipe_id,
              options_from_collection_for_select(recipes_for_slot, :id, :name),
              { prompt: "Add recipe..." },
              { class: "meal-planner-select meal-planner-select-sm" } %>
        <%= f.submit "+", class: "meal-planner-submit meal-planner-submit-sm" %>
      <% end %>
    </div>

    <div class="meal-planner-add-row">
      <%= form_with url: meal_plan_items_path, class: "meal-planner-add-form" do |f| %>
        <%= f.hidden_field :planned_on, value: date %>
        <%= f.hidden_field :meal_slot,  value: slot %>
        <%= f.select :food_item_id,
              grouped_options_for_select(food_items_grouped),
              { prompt: "Add item..." },
              { class: "meal-planner-select meal-planner-select-sm", required: true } %>
        <%= f.number_field :quantity, value: 1, min: 1, class: "meal-plan-qty-input" %>
        <%= f.submit "+", class: "meal-planner-submit meal-planner-submit-sm" %>
      <% end %>
    </div>

    <%= form_with url: toggle_cooked_meal_plan_path(meal_plan), method: :patch,
          data: { turbo_stream: true },
          class: "meal-cell-cook-form" do |f| %>
      <% if meal_plan.meal_plan_items.any? && !meal_plan.cooked? %>
        <%= f.text_field :custom_name,
              placeholder: "#{MealPlan::SLOT_LABELS[meal_plan.meal_slot]} — Custom Items",
              class: "form-input meal-cell-cook-name-input" %>
      <% end %>
      <%= f.submit meal_plan.cooked? ? "↩ Uncook" : "Cook",
            class: "meal-cell-cook-btn #{'meal-cell-cook-btn-done' if meal_plan.cooked?}" %>
    <% end %>

  <% else %>
    <div class="meal-planner-add-row">
      <%= form_with url: meal_plan_recipes_path, class: "meal-planner-add-form" do |f| %>
        <%= f.hidden_field :planned_on, value: date %>
        <%= f.hidden_field :meal_slot,  value: slot %>
        <%= f.select :recipe_id,
              options_from_collection_for_select(recipes_for_slot, :id, :name),
              { prompt: "Add recipe..." },
              { class: "meal-planner-select meal-planner-select-sm" } %>
        <%= f.submit "+", class: "meal-planner-submit meal-planner-submit-sm" %>
      <% end %>
    </div>

    <div class="meal-planner-add-row">
      <%= form_with url: meal_plan_items_path, class: "meal-planner-add-form" do |f| %>
        <%= f.hidden_field :planned_on, value: date %>
        <%= f.hidden_field :meal_slot,  value: slot %>
        <%= f.select :food_item_id,
              grouped_options_for_select(food_items_grouped),
              { prompt: "Add item..." },
              { class: "meal-planner-select meal-planner-select-sm", required: true } %>
        <%= f.number_field :quantity, value: 1, min: 1, class: "meal-plan-qty-input" %>
        <%= f.submit "+", class: "meal-planner-submit meal-planner-submit-sm" %>
      <% end %>
    </div>
  <% end %>
</div>
