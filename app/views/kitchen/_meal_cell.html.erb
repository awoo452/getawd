<div id="meal_cell_<%= date.iso8601 %>_<%= slot %>" class="meal-planner-cell meal-planner-day-cell">
  <% if meal_plan %>
    <% if meal_plan.recipe %>
      <div class="meal-plan-recipe-row">
        <span class="meal-planner-recipe-name"><%= meal_plan.recipe.name %></span>
        <%= button_to "×", remove_recipe_meal_plan_path(meal_plan),
              method: :patch,
              class: "meal-planner-remove",
              form: { data: { turbo_confirm: "Remove recipe?" } } %>
      </div>
    <% end %>

    <% meal_plan.meal_plan_items.each do |item| %>
      <div class="meal-plan-item-row">
        <span class="meal-plan-item-name"><%= item.food_item.name %></span>
        <%= button_to "×", meal_plan_item_path(item),
              method: :delete,
              class: "meal-planner-remove" %>
      </div>
    <% end %>

    <div class="meal-planner-add-row">
      <%= form_with url: meal_plan_items_path, class: "meal-planner-add-form" do |f| %>
        <%= f.hidden_field :planned_on, value: date %>
        <%= f.hidden_field :meal_slot,  value: slot %>
        <%= f.select :food_item_id,
              grouped_options_for_select(food_items_grouped),
              { prompt: "Add item..." },
              { class: "meal-planner-select meal-planner-select-sm", required: true } %>
        <%= f.submit "+", class: "meal-planner-submit meal-planner-submit-sm" %>
      <% end %>
    </div>

    <% unless meal_plan.recipe %>
      <%= button_to "Remove All", meal_plan_path(meal_plan),
            method: :delete,
            class: "meal-planner-remove-all",
            form: { data: { turbo_confirm: "Remove all items?" } } %>
    <% end %>
  <% else %>
    <%= form_with model: MealPlan.new, url: meal_plans_path, class: "meal-planner-form" do |f| %>
      <%= f.hidden_field :planned_on, value: date %>
      <%= f.hidden_field :meal_slot,  value: slot %>
      <%= f.select :recipe_id,
            options_from_collection_for_select(recipes_for_slot, :id, :name),
            { prompt: "Recipe..." },
            class: "meal-planner-select" %>
      <%= f.submit "Plan", class: "meal-planner-submit" %>
    <% end %>

    <div class="meal-planner-add-row">
      <%= form_with url: meal_plan_items_path, class: "meal-planner-add-form" do |f| %>
        <%= f.hidden_field :planned_on, value: date %>
        <%= f.hidden_field :meal_slot,  value: slot %>
        <%= f.select :food_item_id,
              grouped_options_for_select(food_items_grouped),
              { prompt: "Add item..." },
              { class: "meal-planner-select meal-planner-select-sm", required: true } %>
        <%= f.submit "+", class: "meal-planner-submit meal-planner-submit-sm" %>
      <% end %>
    </div>
  <% end %>
</div>
