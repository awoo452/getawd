<div class="meal-planner-nav">
  <%= link_to "← Prev", kitchen_week_path((@week_start - 7.days).strftime("%Y-%m-%d")), class: "kitchen-btn" %>
  <span class="meal-planner-range">
    <%= @week_start.strftime("%b %-d") %> – <%= (@week_start + 6.days).strftime("%b %-d, %Y") %>
  </span>
  <%= link_to "Next →", kitchen_week_path((@week_start + 7.days).strftime("%Y-%m-%d")), class: "kitchen-btn" %>
</div>

<div class="meal-planner-grid">

  <%# Header row %>
  <div class="meal-planner-cell meal-planner-header meal-planner-slot-label"></div>
  <% @week_dates.each do |date| %>
    <div class="meal-planner-cell meal-planner-header <%= 'meal-planner-today' if date == Time.zone.today %>">
      <span class="meal-planner-day-name"><%= date.strftime("%a") %></span>
      <span class="meal-planner-day-num"><%= date.strftime("%-d") %></span>
    </div>
  <% end %>

  <%# Meal slot rows %>
  <% MealPlan::SLOTS.each do |slot| %>
    <div class="meal-planner-cell meal-planner-slot-label">
      <%= slot.capitalize %>
    </div>

    <% @week_dates.each do |date| %>
      <%= render "kitchen/meal_cell",
            date:               date,
            slot:               slot,
            meal_plan:          @meal_plans_by_date_slot[[date, slot]],
            recipes_for_slot:   @recipes_for_slot[slot],
            food_items_grouped: @food_items_grouped %>
    <% end %>
  <% end %>

</div>
