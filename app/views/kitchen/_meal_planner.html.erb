<nav class="meal-planner-mobile-nav">
  <%= link_to "← Prev", kitchen_day_path((@selected_date - 1.day).strftime("%Y-%m-%d")), class: "kitchen-btn" %>
  <span class="meal-planner-range"><%= @selected_date.strftime("%a, %b %-d") %></span>
  <%= link_to "Next →", kitchen_day_path((@selected_date + 1.day).strftime("%Y-%m-%d")), class: "kitchen-btn" %>
</nav>
<div class="meal-planner-nav">
  <%= link_to "← Prev", kitchen_week_path((@week_start - 7.days).strftime("%Y-%m-%d")), class: "kitchen-btn" %>
  <span class="meal-planner-range">
    <%= @week_start.strftime("%b %-d") %> – <%= (@week_start + 6.days).strftime("%b %-d, %Y") %>
  </span>
  <%= link_to "Next →", kitchen_week_path((@week_start + 7.days).strftime("%Y-%m-%d")), class: "kitchen-btn" %>
</div>

<div class="meal-planner-table">

  <%# Header row %>
  <div class="meal-planner-row">
    <div class="meal-planner-label"></div>
    <% @week_dates.each do |date| %>
      <div class="meal-planner-header-cell day-col-<%= date.wday %> <%= 'meal-planner-today' if date == Time.zone.today %>">
        <span class="meal-planner-day-name"><%= date.strftime("%a") %></span>
        <span class="meal-planner-day-num"><%= date.strftime("%-d") %></span>
      </div>
    <% end %>
  </div>

  <%# Meal slot rows %>
  <% MealPlan::SLOTS.each do |slot| %>
    <div class="meal-planner-row">
      <div class="meal-planner-label meal-planner-slot-label">
        <%= MealPlan::SLOT_LABELS[slot] %>
      </div>
      <% @week_dates.each do |date| %>
        <%= render "kitchen/meal_cell",
              date:               date,
              slot:               slot,
              meal_plan:          @meal_plans_by_date_slot[[date, slot]],
              recipes_for_slot:   @recipes_for_slot[slot],
              food_items_grouped: @food_items_grouped %>
      <% end %>
    </div>
  <% end %>

</div>
