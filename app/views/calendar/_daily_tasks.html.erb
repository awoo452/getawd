<section id="task-calendar-daily">
  <%= render "shared/logged_in_heading",
        icon: goal_icons["task"],
        title: "Daily Tasks" %>
  <p class="calendar-daily-date">
    <strong><%= date.strftime("%A, %B %-d, %Y") %></strong>
  </p>
  <% previous_date = date.to_date - 1.day %>
  <% next_date = date.to_date + 1.day %>
  <nav class="calendar-nav">
    <%= link_to "Previous", calendar_daily_date_path(start_date: previous_date), data: { turbo: false } %>
    <%= link_to "Today", calendar_daily_path, data: { turbo: false } %>
    <%= link_to "Next", calendar_daily_date_path(start_date: next_date), data: { turbo: false } %>
  </nav>
  <%= calendar(number_of_days: 1, start_date: date) do |date| %>
    <% tasks_for_date = tasks.select { |task| task.due_date.present? && task.due_date.in_time_zone.to_date == date } %>

    <div class="daily-task-levels">
      <% (1..5).each do |level| %>
        <% level_tasks = tasks_for_date.select { |t| t.priority == level } %>
        <% next if level_tasks.empty? %>

        <div class="task-level">
          <h3>
            <%= link_to "Level #{level}", doc_path("level-#{level}-rewards") %>
          </h3>

          <ul>
            <% level_tasks.each do |task| %>
              <li class="task">
                <%= link_to (goal_icons[task.goal&.category] || "📝"), edit_task_path(task) %>
                <span><%= task.task_name %></span>
                <span class="estimated-time orbitron-text">
                  <%= render "task_time_status", task: task, goal_icons: goal_icons %>
                </span>
                <% unless task.completed? %>
                  <%= button_to "✅",
                        complete_on_time_task_path(task),
                        method: :patch,
                        params: { return_to: request.fullpath },
                        form_class: "quick-complete-form",
                        class: "quick-complete-button",
                        title: "Quick complete",
                        aria: { label: "Quick complete" } %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% other_tasks = tasks_for_date.select { |t| t.priority.blank? || !(1..5).include?(t.priority) } %>
      <% if other_tasks.any? %>
        <div class="task-level">
          <h3>Other Tasks</h3>

          <ul>
            <% other_tasks.each do |task| %>
              <li class="task">
                <%= link_to (goal_icons[task.goal&.category] || "📝"), edit_task_path(task) %>
                <span><%= task.task_name %></span>
                <span class="estimated-time orbitron-text">
                  <%= render "task_time_status", task: task, goal_icons: goal_icons %>
                </span>
                <% unless task.completed? %>
                  <%= button_to "✅",
                        complete_on_time_task_path(task),
                        method: :patch,
                        params: { return_to: request.fullpath },
                        form_class: "quick-complete-form",
                        class: "quick-complete-button",
                        title: "Quick complete",
                        aria: { label: "Quick complete" } %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
