<%= render "shared/logged_in_heading",
      icon: "🐞",
      title: "Add Bug" %>

<%= form_with model: @bug, local: true do |f| %>
  <%= render "shared/form_errors", form_object: @bug %>

  <div class="form-field">
    <%= f.label :title %>
    <%= f.text_field :title, required: true %>
  </div>

  <div class="form-field">
    <%= f.label :section, "Section / Area" %>
    <%= f.text_field :section, placeholder: "dashboard, reports, calendar, etc" %>
  </div>

  <div class="form-field">
    <%= f.label :body, "Details" %>
    <%= f.text_area :body, rows: 5 %>
  </div>

  <%= f.submit "Save Bug", class: "btn" %>

<% end %>
