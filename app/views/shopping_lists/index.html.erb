<%= render "shared/logged_in_heading", title: "Shopping Lists" %>

<div class="kitchen-wrapper">
  <div class="kitchen-actions">
    <%= link_to "← Kitchen", kitchen_path, class: "kitchen-btn" %>
    <% unless @active_list %>
      <%= button_to "Generate New List", shopping_lists_path, method: :post, class: "kitchen-btn kitchen-btn-primary" %>
    <% end %>
  </div>

  <% if @active_list %>
    <section class="kitchen-section">
      <h2 class="kitchen-section-title">🛒 Active List</h2>
      <div class="shopping-list-card shopping-list-active">
        <div class="shopping-list-meta">
          Generated <%= @active_list.generated_on.strftime("%B %-d, %Y") %> &mdash;
          <%= @active_list.checked_count %> / <%= @active_list.total_count %> checked
        </div>
        <div class="shopping-list-actions">
          <%= link_to "Open List", @active_list, class: "kitchen-btn kitchen-btn-primary" %>
          <%= button_to "Archive", archive_shopping_list_path(@active_list), method: :patch, class: "kitchen-btn" %>
          <%= button_to "Delete", @active_list, method: :delete, class: "kitchen-btn kitchen-btn-danger",
                data: { confirm: "Delete this shopping list?" } %>
        </div>
      </div>
    </section>
  <% end %>

  <% if @archived_lists.any? %>
    <section class="kitchen-section">
      <h2 class="kitchen-section-title">📦 Past Lists</h2>
      <% @archived_lists.each do |list| %>
        <div class="shopping-list-card shopping-list-archived">
          <span><%= list.generated_on.strftime("%B %-d, %Y") %></span>
          <span><%= list.total_count %> items</span>
          <%= link_to "View", list, class: "kitchen-btn" %>
          <%= button_to "Delete", list, method: :delete, class: "kitchen-btn kitchen-btn-danger",
                data: { confirm: "Delete this list?" } %>
        </div>
      <% end %>
    </section>
  <% end %>

  <% if @active_list.nil? && @archived_lists.empty? %>
    <p class="kitchen-empty">No shopping lists yet. Generate one when items run low.</p>
  <% end %>
</div>
