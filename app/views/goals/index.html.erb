<%= render "shared/logged_in_heading",
      icon: GOAL_ICONS["goal"],
      title: "Goals" %>

<div class="kanban-board">

  <% @goals_by_status.each do |status, goals| %>
    <div class="kanban-column <%= status %>">
      <h2><%= status.to_s.humanize %></h2>

      <% goals.each do |goal| %>
        <%= render "shared/goal_card", goal: goal %>
      <% end %>
    </div>
  <% end %>

</div>
