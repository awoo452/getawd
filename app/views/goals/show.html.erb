<%= render "shared/logged_in_heading",
      icon: (GOAL_ICONS[@goal.category] || GOAL_ICONS["goal"]),
      title: @goal.title %>

<div class="goals-list">
  <div class="goal-card <%= @goal.status.humanize %>">
    <%= render "goals/details", goal: @goal %>
  </div>
</div>

<%= render "goals/recurring_tasks",
      goal: @goal,
      recurring_tasks: @recurring_tasks,
      recurring_task: @new_recurring_task %>

<%= render "goals/nav", goal: @goal %>
