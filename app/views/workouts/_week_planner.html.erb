<div class="workout-planner-nav">
  <%= link_to "← Prev", workouts_week_path((@week_start - 7.days).strftime("%Y-%m-%d")), class: "workout-btn" %>
  <span class="workout-planner-range">
    <%= @week_start.strftime("%b %-d") %> – <%= (@week_start + 6.days).strftime("%b %-d, %Y") %>
  </span>
  <%= link_to "Next →", workouts_week_path((@week_start + 7.days).strftime("%Y-%m-%d")), class: "workout-btn" %>
</div>

<div class="workout-planner-grid">
  <% @week_dates.each do |date| %>
    <% plan = @workout_plans_by_date[date] %>
    <div class="workout-day-card <%= 'workout-today' if date == Time.zone.today %>">

      <div class="workout-day-header">
        <span class="workout-day-name"><%= date.strftime("%a") %></span>
        <span class="workout-day-num"><%= date.strftime("%-d") %></span>
      </div>

      <div class="workout-day-body">
        <% if plan %>
          <div class="workout-planned">
            <span class="workout-emoji"><%= plan.emoji %></span>
            <span class="workout-label"><%= plan.label %></span>
          </div>
          <%= button_to "×", workout_plan_path(plan),
                method: :delete,
                class: "workout-remove",
                form: { data: { turbo_confirm: "Remove this workout?" } } %>
        <% else %>
          <%= form_with model: WorkoutPlan.new, url: workout_plans_path, class: "workout-form" do |f| %>
            <%= f.hidden_field :planned_on, value: date %>
            <%= f.select :workout_type,
                  WorkoutPlan::TYPES.map { |t| ["#{WorkoutPlan::EMOJIS[t]} #{WorkoutPlan::LABELS[t]}", t] },
                  { prompt: "— plan —" },
                  class: "workout-select" %>
            <%= f.submit "Add", class: "workout-submit" %>
          <% end %>
        <% end %>
      </div>

    </div>
  <% end %>
</div>
