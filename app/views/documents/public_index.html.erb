<%= render "shared/logged_in_heading", title: "Documentation" %>
<section class="documents">
  <div class="documents-index">
    <% if @documents_by_category.blank? %>
      <p>No public documentation is available yet.</p>
    <% else %>
      <% @documents_by_category.sort_by { |category, _| category.to_s.downcase }.each do |category, documents| %>
        <details class="documents-category">
          <summary>
            <span class="documents-category-title"><%= category.to_s.titleize %></span>
            <span class="documents-category-count"><%= documents.size %></span>
          </summary>
          <ul class="documents-list">
            <% documents.each do |document| %>
              <li>
                <%= render document %>
                <%= link_to "View doc", doc_path(document.slug) %>
              </li>
            <% end %>
          </ul>
        </details>
      <% end %>
    <% end %>
  </div>
</section>
