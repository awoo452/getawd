<%= form_with(model: recurring_task, local: true, html: { class: "task_form" }) do |form| %>
  <%= render "shared/form_errors", form_object: recurring_task %>

  <%= render "tasks/form_details", form: form %>
  <%= render "tasks/form_status", form: form, task: recurring_task %>
  <%= render "tasks/form_schedule", form: form, task: recurring_task %>
  <%= render "tasks/form_meta", form: form, task: recurring_task %>

  <div class="form-actions">
    <%= form.submit "Save Recurring Task", class: "form-submit" %>
  </div>
<% end %>
