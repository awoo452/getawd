<%= render "shared/logged_in_heading",
      icon: GOAL_ICONS["task"],
      title: "Recurring Tasks" %>

<div class="tasks-list">
  <ul class="actions-list">
    <li><%= link_to "New Recurring Task", new_recurring_task_path %></li>
    <li><%= link_to "Back to Tasks", tasks_path %></li>
  </ul>

  <% @recurring_tasks.each do |recurring_task| %>
    <div class="task-card <%= recurring_task.status.humanize %>">
      <h2><%= link_to recurring_task.task_name, recurring_task_path(recurring_task) %></h2>
      <p><%= recurring_task.description %></p>
      <p><strong>Goal:</strong> <%= recurring_task.goal&.title || "Not assigned" %></p>
      <p><strong>Priority:</strong> <%= recurring_task.priority %></p>
    </div>
  <% end %>
</div>
