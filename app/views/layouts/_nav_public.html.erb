<ul class="nav-public">
  <li>
    <%= link_to root_path do %>
      <% proxy_url = image_proxy_url("branding/logo.png", width: 300, height: 300, fit: "inside", format: "webp") %>
      <% logo_key = "branding/logo.png" %>
      <% fallback_logo = image_path("branding/logo.png") %>
      <% logo_url = s3_object_exists?(logo_key) ? proxy_url : fallback_logo %>
      <%= fallback_image_tag(logo_url,
                            fallback: fallback_logo,
                            alt: "Logo",
                            class: "navbar-logo",
                            loading: "lazy",
                            decoding: "async") %>
    <% end %>
  </li>
  <li>
    <%= link_to about_path, title: "About", aria: { label: "About" }, data: { tooltip: "About" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
    <% end %>
  </li>
  <li>
    <%= link_to blog_posts_path, title: "Blog", aria: { label: "Blog" }, data: { tooltip: "Blog" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M17 3a2.83 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
