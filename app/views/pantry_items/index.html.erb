<%= render "shared/logged_in_heading", title: "Pantry" %>

<div class="kitchen-wrapper">
  <div class="kitchen-actions">
    <%= link_to "← Kitchen", kitchen_path, class: "kitchen-btn" %>
    <% if ShoppingList.active.any? %>
      <%= link_to "Active Shopping List", ShoppingList.active.first, class: "kitchen-btn kitchen-btn-primary" %>
    <% else %>
      <%= button_to "Generate Shopping List", shopping_lists_path, method: :post, class: "kitchen-btn kitchen-btn-primary" %>
    <% end %>
  </div>

  <div class="pantry-legend">
    <span class="pantry-badge pantry-ok">OK</span>
    <span class="pantry-badge pantry-low">Low</span>
    <span class="pantry-badge pantry-out">Out</span>
  </div>

  <% FoodItem::FOOD_TYPES.each do |food_type| %>
    <% items = @pantry_by_type[food_type] %>
    <% next if items.blank? %>

    <section class="kitchen-section">
      <h2 class="kitchen-section-title">
        <%= FoodItem::FOOD_TYPE_EMOJI[food_type] %> <%= FoodItem::FOOD_TYPE_LABELS[food_type] %>
      </h2>
      <div class="pantry-grid">
        <% items.each do |food_item| %>
          <%= render "pantry_items/pantry_item", pantry_item: food_item.pantry_item %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
